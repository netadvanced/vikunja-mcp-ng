# ---------------------------------------------------------------------------
# EXAMPLE FILE — not a live workflow.
#
# This is the tag-triggered release workflow described in docs/RELEASING.md §6. It is checked
# in under docs/ (as `github-workflow-release.yml.example`) rather than under `.github/workflows/`
# on purpose: this repository currently runs GitHub Actions disabled repo-wide (an explicit owner
# decision — see docs/ROADMAP.md §3b), and installing any workflow is the owner's deliberate act,
# not something that should land silently as a side effect of an unrelated PR.
#
# To install:
#   cp docs/github-workflow-release.yml.example .github/workflows/release.yml
#   git add .github/workflows/release.yml && git commit -m "ci: enable tag-triggered release workflow"
#
# Secrets to add to the repo (Settings → Secrets and variables → Actions) before installing:
#   - NPM_TOKEN     — an npm automation token with publish rights to `vikunja-mcp-ng`
#                     (https://www.npmjs.com/settings/<you>/tokens, type "Automation")
#   - (none needed for GHCR — the built-in GITHUB_TOKEN is sufficient given `packages: write`
#     permission below, and none needed for `gh release create` for the same reason)
#
# Trigger: `on: push: tags: ['v*']` ONLY. Everyday PRs, pushes to main, and other branches are
# completely unaffected by this file's presence — it does nothing until a `vX.Y.Z` tag is pushed,
# which today only happens via `scripts/release-tag.sh` (see docs/RELEASING.md). Once installed,
# that tag push is what triggers this workflow to do the equivalent of
# `scripts/release-publish.sh --push` automatically; the local script remains a manual fallback.
#
# Docker tags produced: `:X.Y.Z`, `:latest`, and `:X.Y.Z-vikunja<A.B.C>` — a per-release
# compatibility tag (e.g. `:0.3.1-vikunja2.3.0`) suffixed with the Vikunja version derived from
# the vendored OpenAPI spec — see scripts/lib/vikunja-compat-version.sh and docs/RELEASING.md
# "Vikunja compatibility".
# ---------------------------------------------------------------------------

name: Release

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write # gh release create
  packages: write # ghcr.io push

jobs:
  release:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0 # full history — needed to read the CHANGELOG.md section for this tag

      - name: Setup Node.js 20
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          registry-url: 'https://registry.npmjs.org'

      - name: Install dependencies
        run: npm ci

      - name: Lint
        run: npm run lint

      - name: Typecheck
        run: npm run typecheck

      - name: Test
        run: npx jest --silent

      - name: Test coverage
        run: npm run test:coverage

      - name: Build
        run: npm run build

      - name: Verify tag matches package.json version
        run: |
          set -euo pipefail
          TAG_NAME="${GITHUB_REF_NAME}"
          PKG_VERSION="v$(node -pe "require('./package.json').version")"
          if [[ "$TAG_NAME" != "$PKG_VERSION" ]]; then
            echo "::error::Tag $TAG_NAME does not match package.json version $PKG_VERSION"
            exit 1
          fi

      - name: Publish to npm
        run: npm publish --access public
        env:
          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Extract version
        id: version
        run: echo "value=${GITHUB_REF_NAME#v}" >> "$GITHUB_OUTPUT"

      - name: Determine Vikunja compatibility version
        id: vikunja-compat
        # Single source of truth: scripts/lib/vikunja-compat-version.sh derives this from the
        # vendored OpenAPI spec (docs/vikunja-openapi.json) and warns loudly on stderr if it
        # disagrees with the e2e docker-compose pin. Never hand-type this version — see
        # docs/RELEASING.md "Vikunja compatibility".
        run: echo "value=$(scripts/lib/vikunja-compat-version.sh)" >> "$GITHUB_OUTPUT"

      - name: Build and push Docker image
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          tags: |
            ghcr.io/netadvanced/vikunja-mcp-ng:${{ steps.version.outputs.value }}
            ghcr.io/netadvanced/vikunja-mcp-ng:latest
            ghcr.io/netadvanced/vikunja-mcp-ng:${{ steps.version.outputs.value }}-vikunja${{ steps.vikunja-compat.outputs.value }}
          labels: |
            org.opencontainers.image.version=${{ steps.version.outputs.value }}
            io.vikunja.compat=${{ steps.vikunja-compat.outputs.value }}

      - name: Extract changelog section for this version
        id: changelog
        run: |
          set -euo pipefail
          VERSION="${{ steps.version.outputs.value }}"
          START_LINE="$(grep -n -E "^## \[${VERSION}\]" CHANGELOG.md | head -1 | cut -d: -f1)"
          if [[ -z "$START_LINE" ]]; then
            echo "::error::No '## [$VERSION]' section found in CHANGELOG.md"
            exit 1
          fi
          END_LINE="$(tail -n "+$((START_LINE + 1))" CHANGELOG.md | grep -n -E '^## \[' | head -1 | cut -d: -f1 || true)"
          if [[ -n "$END_LINE" ]]; then
            END_LINE=$((START_LINE + END_LINE - 1))
          else
            END_LINE="$(wc -l < CHANGELOG.md | tr -d ' ')"
          fi
          sed -n "${START_LINE},${END_LINE}p" CHANGELOG.md > release-notes.md
          cat release-notes.md

      - name: Create GitHub release
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh release create "${GITHUB_REF_NAME}" \
            --title "${GITHUB_REF_NAME}" \
            --notes-file release-notes.md
