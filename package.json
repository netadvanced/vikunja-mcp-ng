{
  "name": "vikunja-mcp-ng",
  "version": "0.3.1",
  "description": "Model Context Protocol server for Vikunja task management - direct-REST, composite-first tools, enterprise-grade security and reliability",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vikunja-mcp-ng": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "docs/CONFIGURATION.md",
    "docs/TOOLS.md",
    "docs/DOCKER-DESKTOP-MCP.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "test": "jest --silent",
    "test:watch": "jest --watch --silent",
    "test:coverage": "jest --coverage --silent",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --config eslint.config.mjs",
    "format:src": "prettier --write 'src/**/*.ts'",
    "format:tests": "prettier --write 'tests/**/*.ts'",
    "format": "npm run format:src && npm run format:tests",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "prepare": "npm run build",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "test:mcp": "tsx scripts/test-mcp.ts",
    "test:e2e:mcp": "tsx scripts/mcp-e2e.ts",
    "capture:samples": "tsx scripts/capture-sample-screenshots.ts",
    "fetch:api-spec": "curl -sS https://try.vikunja.io/api/v1/docs.json -o docs/vikunja-openapi.json && jq -e . docs/vikunja-openapi.json > /dev/null",
    "generate:api-types": "node scripts/generate-api-types.mjs",
    "e2e:up": "docker/e2e/bootstrap.sh",
    "e2e:down": "docker compose -f docker/e2e/docker-compose.yml down -v",
    "release:prepare": "scripts/release-prepare.sh",
    "release:tag": "scripts/release-tag.sh",
    "release:publish": "scripts/release-publish.sh"
  },
  "keywords": [
    "mcp",
    "vikunja",
    "task-management",
    "model-context-protocol",
    "ai-assistant",
    "todo",
    "productivity",
    "automation"
  ],
  "author": "Jeremy Green",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netadvanced/vikunja-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/netadvanced/vikunja-mcp/issues"
  },
  "homepage": "https://github.com/netadvanced/vikunja-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "async-mutex": "^0.5.0",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express-rate-limit": "^8.6.0",
    "jsonata": "^2.2.2",
    "object-sizeof": "^2.6.5",
    "opossum": "^9.0.0",
    "tslib": "^2.8.1",
    "uuid": "^11.1.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.3.0",
    "@types/opossum": "^8.1.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^9.33.0",
    "eslint-plugin-jest": "^29.0.1",
    "fast-check": "^4.3.0",
    "globals": "^16.3.0",
    "jest": "^30.0.5",
    "markdown-it": "^14.3.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "prettier": "^3.0.0",
    "swagger2openapi": "^7.0.8",
    "ts-jest": "^29.4.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 79,
        "functions": 77,
        "lines": 88,
        "statements": 88
      }
    }
  },
  "overrides": {
    "zod": "^3.25.28",
    "qs": "^6.15.3",
    "fast-uri": "^3.1.3",
    "path-to-regexp": "^8.4.2",
    "body-parser": "^2.3.0",
    "@modelcontextprotocol/sdk": {
      "ajv": "^8.20.0"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
